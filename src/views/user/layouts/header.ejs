<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'Alpha Books' %></title>
    <link rel="stylesheet" href="/css/user/style.css">
</head>
<body>

<header style="background-color: #1e293b; padding: 20px; color: white; display: flex; justify-content: space-between; align-items: center;">
    
    <div style="display: flex; align-items: center; gap: 12px; padding: 5px 0;">
        <img src="/images/logo.png" alt="Alpha Books Logo" style="height: 60px; width: auto; object-fit: contain; filter: brightness(0) invert(1);">
    </div>

    <nav>
        <a href="/" style="color: white; text-decoration: none; margin-right: 20px; font-weight: 500;">Home</a>
        
        <% if (locals.user) { %>
            <a href="/profile" style="color: white; text-decoration: none; margin-right: 20px;">Profile</a>
            <a href="/logout" style="color: white; text-decoration: none; background-color: #fa5252; padding: 8px 16px; border-radius: 4px;">Logout</a>
        <% } else { %>
            <a href="/login" style="color: white; text-decoration: none; margin-right: 20px;">Login</a>
            <a href="/signup" style="color: white; text-decoration: none; background-color: #fa5252; padding: 8px 16px; border-radius: 4px;">Sign Up</a>
        <% } %>
    </nav>

</header>