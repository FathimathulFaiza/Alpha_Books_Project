<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        body {
            background-color: #f8f9fa;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .otp-card {
            max-width: 450px;
            width: 100%;
            padding: 30px;
            border-radius: 10px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            background-color: #ffffff;
        }
        /* Custom styling for individual OTP boxes */
        .otp-box {
            width: 45px;
            height: 50px;
            font-size: 24px;
            font-weight: bold;
            text-align: center;
            border: 2px solid #ced4da;
            border-radius: 6px;
        }
        /* Highlight the active input box inside the UI */
        .otp-box:focus {
            border-color: #0d6efd;
            box-shadow: 0 0 5px rgba(13, 110, 253, 0.3);
            outline: none;
        }
    </style>
</head>
<body>

<div class="otp-card text-center">
    <h3 class="mb-3">OTP Verification</h3>
    <p class="text-muted small">We have sent a 6-digit OTP to your registered email address.</p>

    <form id="otpForm" action="/otp-verify" method="POST" class="mt-4">
        
        <div class="d-flex justify-content-center gap-2 mb-4">
            <input type="text" class="form-control otp-box" maxlength="1" required pattern="\d">
            <input type="text" class="form-control otp-box" maxlength="1" required pattern="\d">
            <input type="text" class="form-control otp-box" maxlength="1" required pattern="\d">
            <input type="text" class="form-control otp-box" maxlength="1" required pattern="\d">
            <input type="text" class="form-control otp-box" maxlength="1" required pattern="\d">
            <input type="text" class="form-control otp-box" maxlength="1" required pattern="\d">
        </div>

        <input type="hidden" name="otp" id="finalOtp">
        
        <button type="submit" class="btn btn-primary w-100 py-2 fs-5">Verify & Register</button>
    </form>

    <div class="mt-4">
        <p id="timerText" class="text-muted">OTP will expire in: <span id="timer" class="text-danger fw-bold">02:00</span></p>
        <a href="/resend-otp" id="resendBtn" class="btn btn-link text-primary text-decoration-none fw-bold" style="display: none;">Resend OTP</a>
    </div>
</div>

<script>
    const inputs = document.querySelectorAll('.otp-box');
    const otpForm = document.getElementById('otpForm');
    const finalOtpInput = document.getElementById('finalOtp');

    // 1. Logic for shifting focus automatically between the 6 boxes
    inputs.forEach((input, index) => {
        // Move to the next box when user types a digit
        input.addEventListener('input', (e) => {
            if (input.value.length === 1 && index < inputs.length - 1) {
                inputs[index + 1].focus();
            }
        });

        // Move to the previous box when user hits the Backspace key
        input.addEventListener('keydown', (e) => {
            if (e.key === 'Backspace' && input.value.length === 0 && index > 0) {
                inputs[index - 1].focus();
            }
        });
    });

    // 2. Allow user to copy a 6-digit OTP and paste it directly into the first box
    inputs[0].addEventListener('paste', (e) => {
        const pasteData = e.clipboardData.getData('text');
        // Check if pasted data is exactly 6 digits long
        if (pasteData.length === 6 && /^\d+$/.test(pasteData)) {
            inputs.forEach((input, index) => {
                input.value = pasteData[index];
            });
            inputs[5].focus(); // Automatically focus on the last box after pasting
            e.preventDefault();
        }
    });

    // 3. Before the form submits, merge all 6 individual box digits into the hidden input
    otpForm.addEventListener('submit', (e) => {
        let combinedOtp = "";
        inputs.forEach(input => {
            combinedOtp += input.value;
        });
        finalOtpInput.value = combinedOtp; // Put the 6-digit string into the hidden field
    });


    // 4. Two-minute Countdown Timer logic
    let timeLeft = 120; 
    const timerElement = document.getElementById('timer');
    const timerText = document.getElementById('timerText');
    const resendBtn = document.getElementById('resendBtn');

    const countdown = setInterval(() => {
        if (timeLeft <= 0) {
            clearInterval(countdown);
            timerText.style.display = 'none';
            resendBtn.style.display = 'inline-block';
        } else {
            let minutes = Math.floor(timeLeft / 60);
            let seconds = timeLeft % 60;
            let formattedMinutes = minutes < 10 ? '0' : '';
            let formattedSeconds = seconds < 10 ? '0' : '';
            timerElement.innerHTML = `${formattedMinutes}${minutes}:${formattedSeconds}${seconds}`;
        }
        timeLeft -= 1;
    }, 1000);
</script>

</body>
</html>