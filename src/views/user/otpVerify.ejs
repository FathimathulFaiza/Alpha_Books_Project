<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #f8f9fa;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .otp-card {
            max-width: 400px;
            width: 100%;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            background: white;
        }
        .otp-inputs input {
            width: 45px;
            height: 50px;
            font-size: 20px;
            text-align: center;
            border: 2px solid #ced4da;
            border-radius: 6px;
            margin: 0 5px;
        }
        .otp-inputs input:focus {
            border-color: #0d6efd;
            outline: none;
        }
    </style>
</head>
<body>

<div class="otp-card text-center">
    <div class="brand-logo h3 text-primary fw-bold mb-3">Alpha Books</div>
    <h4 class="fw-bold mb-2">Security Verification</h4>
    <p class="text-muted small mb-4">We have sent a 6-digit OTP to your registered email address. It will expire in 2 minutes.</p>
    
    <form action="/otp-verify" method="POST" id="otpForm">
        <div class="otp-inputs d-flex justify-content-center mb-4">
            <input type="text" maxlength="1" class="otp-field" required pattern="\d" inputmode="numeric">
            <input type="text" maxlength="1" class="otp-field" required pattern="\d" inputmode="numeric">
            <input type="text" maxlength="1" class="otp-field" required pattern="\d" inputmode="numeric">
            <input type="text" maxlength="1" class="otp-field" required pattern="\d" inputmode="numeric">
            <input type="text" maxlength="1" class="otp-field" required pattern="\d" inputmode="numeric">
            <input type="text" maxlength="1" class="otp-field" required pattern="\d" inputmode="numeric">
        </div>

        <input type="hidden" name="otp" id="finalOtp">

        <button type="submit" class="btn btn-primary w-100 mb-3">Verify & Proceed</button>
    </form>
</div>

<script>
    const inputs = document.querySelectorAll('.otp-field');
    const finalOtpInput = document.getElementById('finalOtp');
    const form = document.getElementById('otpForm');

    inputs.forEach((input, index) => {
        input.addEventListener('input', (e) => {
            if (e.target.value.length === 1 && index < inputs.length - 1) {
                inputs[index + 1].focus();
            }
            updateFinalOtp();
        });

        input.addEventListener('keydown', (e) => {
            if (e.key === 'Backspace' && e.target.value.length === 0 && index > 0) {
                inputs[index - 1].focus();
            }
        });
    });

    function updateFinalOtp() {
        let otpValue = "";
        inputs.forEach(input => {
            otpValue += input.value;
        });
        finalOtpInput.value = otpValue;
    }

    form.addEventListener('submit', (e) => {
        updateFinalOtp();
        if (finalOtpInput.value.length !== 6) {
            e.preventDefault();
            alert("Please enter all 6 digits.");
        }
    });
</script>

</body>
</html>