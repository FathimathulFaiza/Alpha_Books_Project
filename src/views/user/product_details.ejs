<!DOCTYPE html>
<html>
<head>
  <title><%= product.title %> | Alpha Books</title>
  <link rel="stylesheet" href="/public/css/style.css">
</head>

<body>

<%- include("../partials/header") %>

<main class="product-wrapper">

  <div class="product-card">

    <!-- LEFT : IMAGE -->
    <div class="product-image">
      <img 
        src="<%= product.images[0] || '/public/images/placeholder.png' %>" 
        alt="<%= product.title %>"
      />
    </div>

    <!-- RIGHT : DETAILS -->
    <div class="product-info">
      <h1><%= product.title %></h1>
      <p class="author">by <%= product.author %></p>

      <p class="price">₹<%= product.price %></p>

      <p class="description">
        <%= product.description %>
      </p>

      <p class="stock <%= product.stock > 0 ? 'in-stock' : 'out-stock' %>">
        <%= product.stock > 0 ? 'In Stock' : 'Out of Stock' %>
      </p>

      <div class="actions">
        <button class="btn primary">Add to Cart</button>
        <button class="btn secondary">Wishlist</button>
      </div>
    </div>

  </div>

</main>

<%- include("../partials/footer") %>

</body>
</html>