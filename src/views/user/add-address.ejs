<%- include('layouts/header') %>

<div class="container mt-5 mb-5">
    <div class="row">
        
        <div class="col-lg-3 col-md-4 mb-4">
            <div class="bg-light p-4 rounded shadow-sm">
                <h5 class="fw-bold mb-3 text-dark">Manage My Account</h5>
                <div class="list-group list-group-flush account-sidebar">
                    <a href="/profile" class="list-group-item list-group-item-action bg-transparent ps-0 border-0 py-2 text-muted">My Profile</a>
                    <a href="/addresses" class="list-group-item list-group-item-action bg-transparent ps-0 border-0 py-2 fw-bold text-primary">Address Book</a>
                    <a href="/orders" class="list-group-item list-group-item-action bg-transparent ps-0 border-0 py-2 text-muted">My Orders</a>
                    <a href="/wishlist" class="list-group-item list-group-item-action bg-transparent ps-0 border-0 py-2 text-muted">My Wishlist</a>
                </div>
            </div>
        </div>

        <div class="col-lg-9 col-md-8">
            <div class="bg-light p-4 rounded shadow-sm">
                <h3 class="mb-4 fw-bold text-dark">Add New Address</h3>
                
                <form action="/addresses/add" method="POST">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">First Name *</label>
                            <input type="text" name="firstName" class="form-control" placeholder="First Name" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Last Name *</label>
                            <input type="text" name="lastName" class="form-control" placeholder="Last Name" required>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Email ID (Optional)</label>
                            <input type="email" name="email" class="form-control" placeholder="Email">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Phone Number *</label>
                            <input type="tel" name="mobile" class="form-control" placeholder="Phone Number" required>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Address *</label>
                        <textarea name="addressLine" class="form-control" rows="3" placeholder="Enter your full address" required></textarea>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">District / Town *</label>
                            <input type="text" name="cityOrDistrict" class="form-control" placeholder="District" required>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">State *</label>
                            <input type="text" name="state" class="form-control" placeholder="State" required>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Pin Code *</label>
                            <input type="text" name="pincode" class="form-control" placeholder="Pin Code" required>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Landmark (Optional)</label>
                        <input type="text" name="landmark" class="form-control" placeholder="Near by landmark">
                    </div>

                    <div class="mb-4">
                        <label class="form-label d-block">Address Type *</label>
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="radio" name="addressType" value="Home" checked>
                            <label class="form-check-label">Home</label>
                        </div>
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="radio" name="addressType" value="Work">
                            <label class="form-check-label">Work / Office</label>
                        </div>
                    </div>

                    <div class="text-end">
                        <a href="/addresses" class="btn btn-secondary me-2">Cancel</a>
                        <button type="submit" class="btn btn-dark px-4">Save Address</button>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>

<%- include('layouts/footer') %>