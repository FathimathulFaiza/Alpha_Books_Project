<%- include('layouts/header') %>

<main style="max-width: 1100px; margin: 60px auto; padding: 0 20px; font-family: 'Inter', sans-serif; display: flex; align-items: center; gap: 60px; min-height: 80vh; margin-bottom: 120px;">
    
    <div style="flex: 1; display: flex; justify-content: center; align-items: center;">
        <img src="/images/book_signup.jpg" 
             alt="Alpha Books Signup" 
             style="width: 100%; max-width: 500px; height: 550px; object-fit: cover; border-radius: 4px;">
    </div>

    <div style="flex: 1; max-width: 420px;">
        
        <div style="margin-bottom: 30px;">
            <h2 style="color: #000000; font-size: 32px; font-weight: 500; margin-bottom: 10px; letter-spacing: 0.5px;">Create an account</h2>
            <p style="color: #000000; font-size: 16px; opacity: 0.8;">Enter your details below</p>
        </div>

        <form action="/signup" method="POST" style="display: flex; flex-direction: column; gap: 25px;">
            
            <div style="display: flex; flex-direction: column; gap: 2px;">
                <input type="text" id="firstName" name="firstName" placeholder="First Name" required 
                       style="width: 100%; padding: 10px 0; border: none; border-bottom: 1px solid #cccccc; font-size: 16px; outline: none; background: transparent;">
            </div>

            <div style="display: flex; flex-direction: column; gap: 2px;">
                <input type="text" id="lastName" name="lastName" placeholder="Last Name" required 
                       style="width: 100%; padding: 10px 0; border: none; border-bottom: 1px solid #cccccc; font-size: 16px; outline: none; background: transparent;">
            </div>

            <div style="display: flex; flex-direction: column; gap: 2px;">
                <input type="email" id="email" name="email" placeholder="Email" required 
                       style="width: 100%; padding: 10px 0; border: none; border-bottom: 1px solid #cccccc; font-size: 16px; outline: none; background: transparent;">
            </div>

            <div style="display: flex; flex-direction: column; gap: 2px;">
                <input type="password" id="password" name="password" placeholder="Password" required 
                       style="width: 100%; padding: 10px 0; border: none; border-bottom: 1px solid #cccccc; font-size: 16px; outline: none; background: transparent;">
            </div>

            <button type="submit" style="background-color: #000000; color: white; padding: 16px; border: none; border-radius: 4px; font-size: 16px; font-weight: 500; cursor: pointer; margin-top: 10px; width: 100%;">
                Create Account
            </button>

            <button type="button" style="background-color: transparent; color: #000000; padding: 14px; border: 1px solid #cccccc; border-radius: 4px; font-size: 16px; font-weight: 400; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 10px; width: 100%;">
                <img src="https://fonts.gstatic.com/s/i/productlogos/googleg/v6/24px.svg" alt="Google Logo" style="width: 20px; height: 20px;">
                Sign up with Google
            </button>

        </form>

        <div style="text-align: center; margin-top: 30px; color: #000000; opacity: 0.7; font-size: 16px;">
            Already have account? <a href="/login" style="color: #000000; text-decoration: underline; font-weight: 500; margin-left: 10px;">Log in</a>
        </div>

    </div>

</main>

<%- include('layouts/footer') %>