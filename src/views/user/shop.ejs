<!DOCTYPE html>
<html>
<head>
  <title>Shop | Alpha Books</title>
  <link rel="stylesheet" href="/public/css/style.css">
</head>

<body>

<%- include("../partials/header") %>

<main class="shop-wrapper">

  <!-- SIDEBAR -->
  <aside class="shop-sidebar">
    <h3>Categories</h3>
    <ul>
      <% categories.forEach(cat => { %>
        <li class="<%= selectedCategory == cat._id.toString() ? 'active' : '' %>">
          <a href="/shop?category=<%= cat._id %>">
            <%= cat.name %>
          </a>
        </li>
      <% }) %>
    </ul>
  </aside>

  <!-- MAIN CONTENT -->
  <section class="shop-main">

    <!-- FILTER BAR -->
    <form method="GET" action="/shop" class="shop-filters">

      <input
        type="text"
        name="search"
        placeholder="Search by book or author"
        value="<%= search %>"
      />

      <% if (selectedCategory) { %>
        <input type="hidden" name="category" value="<%= selectedCategory %>">
      <% } %>

      <select name="sort">
        <option value="">Sort</option>
        <option value="price_asc">Price: Low → High</option>
        <option value="price_desc">Price: High → Low</option>
        <option value="name_asc">Name: A → Z</option>
        <option value="name_desc">Name: Z → A</option>
      </select>

      <button type="submit">Apply</button>
    </form>

    <h1 class="page-title">Books Collection</h1>

    <!-- PRODUCTS -->
    <% if (products.length === 0) { %>
      <p class="empty-state">No products found</p>
    <% } else { %>
      <div class="products-grid">
        <% products.forEach(product => { %>
          <div class="product-card">
            <h3>
              <a href="/product/<%= product._id %>">
                <%= product.title %>
              </a>
            </h3>
            <p class="author"><%= product.author %></p>
            <p class="price">₹<%= product.price %></p>
          </div>
        <% }) %>
      </div>
    <% } %>

    <!-- PAGINATION -->
    <% if (totalPages > 1) { %>
      <div class="pagination">
        <% for (let i = 1; i <= totalPages; i++) { %>
          <a
            class="<%= currentPage === i ? 'active' : '' %>"
            href="/shop?category=<%= selectedCategory || '' %>&search=<%= search %>&page=<%= i %>"
          >
            <%= i %>
          </a>
        <% } %>
      </div>
    <% } %>

  </section>

</main>

<%- include("../partials/footer") %>

</body>
</html>