<!DOCTYPE html>
<html>
<head>
  <title>Shop | Alpha Books</title>
  <link rel="stylesheet" href="/public/css/style.css">
</head>

<body>

<%- include("../partials/header") %>

<main class="shop-container" style="display:flex; gap:20px; padding:20px;">

  <!-- LEFT SIDEBAR : CATEGORIES -->
  <aside style="width:220px; border-right:1px solid #ddd; padding-right:15px;">
    <h3>Categories</h3>

    <ul style="list-style:none; padding:0;">
      <% categories.forEach(cat => { %>
        <li style="margin-bottom:8px;">
          <a 
            href="/shop?category=<%= cat._id %>"
            style="
              text-decoration:none;
              <%= selectedCategory == cat._id.toString() 
                ? 'font-weight:bold;color:blue;' 
                : 'color:black;' %>
            "
          >
            <%= cat.name %>
          </a>
        </li>
      <% }) %>
    </ul>
  </aside>

  <!-- RIGHT SIDE : PRODUCTS -->
  <section style="flex:1; padding-left:15px;">
    <h1>Books Collection</h1>

    <% if (products.length === 0) { %>
      <p>No products available for this category</p>
    <% } else { %>
      <ul style="list-style:none; padding:0;">
        <% products.forEach(product => { %>
          <li style="margin-bottom:15px; border-bottom:1px solid #eee; padding-bottom:10px;">
            <a href="/product/<%= product._id %>" style="text-decoration:none;">
              <strong><%= product.title %></strong>
            </a>
            <br>
            <small>Author: <%= product.author %></small>
            <br>
            <span>Price: ₹<%= product.price %></span>
          </li>
        <% }) %>
      </ul>
    <% } %>

    <!-- PAGINATION -->
    <% if (totalPages > 1) { %>
      <div style="margin-top:20px;">
        <% for (let i = 1; i <= totalPages; i++) { %>
          <a
            href="/shop?category=<%= selectedCategory %>&search=<%= search %>&page=<%= i %>"
            style="
              margin-right:8px;
              text-decoration:none;
              <%= currentPage === i 
                ? 'font-weight:bold;color:blue;' 
                : 'color:black;' %>
            "
          >
            <%= i %>
          </a>
        <% } %>
      </div>
    <% } %>

  </section>

</main>

<%- include("../partials/footer") %>

</body>
</html>