<%- include('/layouts/header') %>

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-warning text-dark text-center">
                    <h4>Change Your Email Address</h4>
                </div>
                <div class="card-body p-4">

                    <% if (error) { %>
                        <div class="alert alert-danger text-center" role="alert">
                            <%= error %>
                        </div>
                    <% } %>

                    <% if (message) { %>
                        <div class="alert alert-success text-center" role="alert">
                            <%= message %>
                        </div>
                    <% } %>

                    <form action="/change-email" method="POST">
                        
                        <div class="mb-4">
                            <label for="newEmail" class="form-label">Enter New Email Address</label>
                            <input 
                                type="email" 
                                class="form-control" 
                                id="newEmail" 
                                name="newEmail" 
                                placeholder="example@gmail.com" 
                                required
                            >
                            <div class="form-text text-muted">
                                We will send a 6-digit verification OTP to this new email address.
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center">
                            <a href="/profile" class="btn btn-secondary">Cancel</a>
                            
                            <button type="submit" class="btn btn-warning">Send Verification OTP</button>
                        </div>

                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

<%- include('/layouts/footer') %>