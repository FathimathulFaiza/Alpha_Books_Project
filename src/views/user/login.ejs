<%- include('layouts/header') %>

<main style="max-width: 1100px; margin: 60px auto; padding: 0 20px; font-family: 'Inter', sans-serif; display: flex; align-items: center; gap: 60px; min-height: 80vh; margin-bottom: 120px;">
    
    <div style="flex: 1; display: flex; justify-content: center; align-items: center;">
        <img src="/images/book_signup.jpg" 
             alt="Alpha Books Login" 
             style="width: 100%; max-width: 500px; height: 550px; object-fit: cover; border-radius: 4px;">
    </div>

    <div style="flex: 1; max-width: 420px;">
        
        <div style="margin-bottom: 30px;">
            <h2 style="color: #000000; font-size: 32px; font-weight: 500; margin-bottom: 10px; letter-spacing: 0.5px;">Log in to Exclusive</h2>
            <p style="color: #000000; font-size: 16px; opacity: 0.8;">Enter your details below</p>
        </div>

        <% if (locals.errorMessage) { %>
            <div style="color: #db4444; background-color: #fdf2f2; padding: 10px; border-radius: 4px; margin-bottom: 15px; font-size: 14px;">
                <%= errorMessage %>
            </div>
        <% } %>

        <form action="/login" method="POST" style="display: flex; flex-direction: column; gap: 25px;">
            
            <div style="display: flex; flex-direction: column; gap: 2px;">
                <input type="email" id="email" name="email" placeholder="Email" required 
                       style="width: 100%; padding: 10px 0; border: none; border-bottom: 1px solid #cccccc; font-size: 16px; outline: none; background: transparent;">
            </div>

            <div style="display: flex; flex-direction: column; gap: 2px;">
                <input type="password" id="password" name="password" placeholder="Password" required 
                       style="width: 100%; padding: 10px 0; border: none; border-bottom: 1px solid #cccccc; font-size: 16px; outline: none; background: transparent;">
            </div>

            <div style="text-align: right; margin-top: -5px;">
                <a href="/forgot-password" style="color: #db4444; text-decoration: none; font-size: 14px; font-weight: 400;">Forgot Password?</a>
            </div>

            <button type="submit" style="background-color: #000000; color: white; padding: 16px; border: none; border-radius: 4px; font-size: 16px; font-weight: 500; cursor: pointer; margin-top: 10px; width: 100%;">
                Log In
            </button>

            <a href="/auth/google" style="background-color: transparent; color: #000000; padding: 14px; border: 1px solid #cccccc; border-radius: 4px; font-size: 16px; font-weight: 400; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 10px; width: 100%; text-decoration: none;">
    <img src="https://fonts.gstatic.com/s/i/productlogos/googleg/v6/24px.svg" alt="Google Logo" style="width: 20px; height: 20px;">
    Sign in with Google
</a>

        </form>

        <div style="text-align: center; margin-top: 30px; color: #000000; opacity: 0.7; font-size: 16px;">
            Don't have account? <a href="/signup" style="color: #000000; text-decoration: underline; font-weight: 500; margin-left: 10px;">Sign Up</a>
        </div>

    </div>

</main>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    const urlParams = new URLSearchParams(window.location.search);     // sweet alert error msg for blocked user
    
    // 1. checking the user is blocked
    if (urlParams.get('blocked') === 'true') {
        Swal.fire({
            icon: 'error',
            title: 'Account Blocked!',
            text: 'Your account has been blocked by the admin. Please contact support.',
            confirmButtonColor: '#3085d6',
            confirmButtonText: 'OK',
            didClose: () => {
                window.history.replaceState({}, document.title, window.location.pathname);
            }
        });
    }
    // 2. checking any other error is there, if yes it shown through the url
    else if (urlParams.has('error')) {
        const errorMessage = urlParams.get('error');
        Swal.fire({
            icon: 'error',
            title: 'Oops!',
            text: errorMessage, // URL- error msg
            confirmButtonColor: '#3085d6',
            confirmButtonText: 'OK',
            didClose: () => {
                window.history.replaceState({}, document.title, window.location.pathname);
            }
        });
    }
</script>

<%- include('layouts/footer') %>