
<%- include('layouts/header') %>

<div class="container mt-5 mb-5 d-flex justify-content-center">
    <div class="card border-0 shadow p-4 rounded" style="max-width: 450px; width: 100%;">
        <div class="card-body text-center">
            <h4 class="fw-bold mb-3 text-dark">Verify Your Email</h4>
            <p class="text-muted small mb-4">An OTP has been sent to your new email address. Please enter the 6-digit code below to verify.</p>

            <% if (locals.error) { %>
                <div class="alert alert-danger small p-2" role="alert">
                    <%= error %>
                </div>
            <% } %>

            <form action="/change-email-verify" method="POST">
                <div class="mb-4">
                    <input type="text" class="form-control text-center fw-bold fs-4" id="otp" name="otp" placeholder="000000" maxlength="6" required>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-dark py-2">Verify OTP</button>
                </div>
            </form>

            <div class="mb-3 mt-3">
                <span id="timer-text" class="text-muted small">OTP expires in: <b id="timer" class="text-danger">02:00</b></span>
                <form action="/resend-otp" method="POST" style="display: inline;">
                    <button type="submit" id="resend-link" class="btn btn-link text-primary small fw-bold d-none p-0">Resend OTP</button>
                </form>
            </div>

            <div class="d-grid gap-2">
                <a href="/profile" class="btn btn-light py-2 text-muted small">Cancel</a>
            </div>
        </div>
    </div>
</div>

<script>
    let timeLeft = 120; // 120 സെക്കൻഡ് (2 മിനിറ്റ്)
    const timerElement = document.getElementById('timer');
    const timerTextElement = document.getElementById('timer-text');
    const resendLink = document.getElementById('resend-link');

    const countdown = setInterval(() => {
        if (timeLeft <= 0) {
            clearInterval(countdown);
            timerTextElement.classList.add('d-none');
            resendLink.classList.remove('d-none');
        } else {
            let minutes = Math.floor(timeLeft / 60);
            let seconds = timeLeft % 60;

            minutes = minutes < 10 ? '0' + minutes : minutes;
            seconds = seconds < 10 ? '0' + seconds : seconds;

            timerElement.textContent = minutes + ':' + seconds;
            timeLeft--;
        }
    }, 1000);
</script>

<%- include('layouts/footer') %>