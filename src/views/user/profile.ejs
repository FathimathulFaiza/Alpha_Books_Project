<%- include('layouts/header') %>

<div class="container mt-5 mb-5">
    <% if (typeof message !== 'undefined' && message) { %> <div class="alert alert-success"><%= message %></div> <% } %>
    <% if (typeof error !== 'undefined' && error) { %> <div class="alert alert-danger"><%= error %></div> <% } %>

    <div class="row">
        <div class="col-lg-3 col-md-4 mb-4">
            <div class="bg-light p-4 rounded shadow-sm">
                <h5 class="fw-bold mb-3 text-dark">Manage My Account</h5>
                <div class="list-group list-group-flush account-sidebar">
                    <a href="/profile" class="list-group-item list-group-item-action bg-transparent ps-0 border-0 py-2 fw-bold text-primary">My Profile</a>
                    <a href="/addresses" class="list-group-item list-group-item-action bg-transparent ps-0 border-0 py-2 text-muted">Address Book</a>
                    <a href="/orders" class="list-group-item list-group-item-action bg-transparent ps-0 border-0 py-2 text-muted">My Orders</a>
                    <a href="/wishlist" class="list-group-item list-group-item-action bg-transparent ps-0 border-0 py-2 text-muted">My Wishlist</a>
                </div>
            </div>
        </div>

        <div class="col-lg-9 col-md-8">
            <div class="bg-light p-4 rounded shadow-sm">
                <h3 class="mb-4 fw-bold text-dark">My Profile</h3>
                
                <div class="row mt-4">
                    <div class="col-md-4 text-center mb-4">
                        <div class="profile-img-container mb-3">
                         <img src="<%= (user.profileImage || '/images/default-avatar.png') %>?t=<%= new Date().getTime() %>" alt="Profile Image" class="rounded-circle img-thumbnail" style="width: 150px; height: 150px; object-fit: cover;">
                            <div class="mt-2">
                                <button type="button" class="btn btn-sm btn-outline-dark" data-bs-toggle="modal" data-bs-target="#uploadModal">
                                    Change Photo
                                </button>
                            </div>
                        </div>
                        <h5 class="fw-bold"><%= user.firstName %> <%= user.lastName %></h5>
                        <p class="text-muted">Customer</p>
                    </div>

                    <div class="col-md-8">
                        <div class="card border-0 bg-white p-4 rounded shadow-sm mb-4">
                            <h5 class="fw-bold mb-3 text-secondary">Personal Information</h5>
                            <div class="row">
                                <div class="col-sm-6 mb-3">
                                    <small class="text-muted d-block">First Name</small>
                                    <span class="fw-semibold"><%= user.firstName %></span>
                                </div>
                                <div class="col-sm-6 mb-3">
                                    <small class="text-muted d-block">Last Name</small>
                                    <span class="fw-semibold"><%= user.lastName %></span>
                                </div>
                                <div class="col-sm-6 mb-3">
                                    <small class="text-muted d-block">Email Address</small>
                                    <div class="d-flex align-items-center justify-content-between">
                                        <span class="fw-semibold"><%= user.email %></span>
                                        <button type="button" class="btn btn-sm btn-link text-primary text-decoration-none p-0" data-bs-toggle="modal" data-bs-target="#changeEmailModal">
                                            Change
                                        </button>
                                    </div>
                                </div>
                              <div class="col-sm-6 mb-3">
    <small class="text-muted d-block">Phone Number</small>
    <span class="fw-semibold">
        <%= user.mobile ? user.mobile : (typeof primaryAddress !== 'undefined' && primaryAddress ? primaryAddress.mobile : 'Not Provided') %>
    </span>
</div>
                            </div>
                            <div class="text-end mt-2">
                                <a href="/edit-profile" class="btn btn-sm btn-dark px-3">Edit Profile</a>
                            </div>
                        </div>

                        <div class="card border-0 bg-white p-4 rounded shadow-sm">
                            <h5 class="fw-bold mb-3 text-secondary">Primary Shipping Address</h5>
                            <% if (typeof primaryAddress !== 'undefined' && primaryAddress) { %>
                                <h5 class="mb-1 fw-bold"><%= primaryAddress.firstName %> <%= primaryAddress.lastName %></h5>
                                <p class="mb-1 text-muted"><%= primaryAddress.addressLine %></p>
                                <p class="mb-1 text-muted"><%= primaryAddress.cityOrDistrict %>, <%= primaryAddress.state %> - <%= primaryAddress.pincode %></p>
                                <p class="mb-0 text-muted">Phone: <%= primaryAddress.mobile %></p>
                            <% } else { %>
                                <p class="text-muted mb-0">No primary address set. <a href="/addresses" class="text-primary text-decoration-none">Add Address</a></p>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="changeEmailModal" tabindex="-1" aria-labelledby="changeEmailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title fw-bold" id="changeEmailModalLabel">Change Email Address</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form action="/change-email" method="POST">
                <div class="modal-body p-4">
                    <p class="text-muted small mb-3">Please enter your new email address below. A verification code (OTP) will be sent to this email.</p>
                    <div class="mb-3">
                        <label for="newEmail" class="form-label fw-semibold text-secondary">New Email Address</label>
                        <input type="email" class="form-control" id="newEmail" name="newEmail" placeholder="example@gmail.com" required>
                    </div>
                </div>
                <div class="modal-footer border-0 px-4 pb-4">
                    <button type="button" class="btn btn-light px-3" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-dark px-4">Send OTP</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="uploadModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <form action="/update-profile" method="POST" enctype="multipart/form-data" class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-bold">Update Profile Picture</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <input type="file" name="profileImage" class="form-control" accept="image/*" required>
                <small class="text-muted">Select an image file (jpg, png, etc.)</small>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-dark">Upload</button>
            </div>
        </form>
    </div>
</div>

//sweet alert
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    const urlParams = new URLSearchParams(window.location.search);
    const message = urlParams.get('message');
    const type = urlParams.get('type') || 'success'; // 'type' ഇല്ലെങ്കിൽ ഡിഫോൾട്ട് ആയി 'success' എടുക്കും

    if (message) {
        Swal.fire({
            icon: type, // ഇവിടെ success, error, warning എന്നിങ്ങനെ മാറിക്കൊണ്ടിരിക്കും
            title: type === 'error' ? 'Oops!' : 'Success!',
            text: message,
            confirmButtonText: 'OK'
        });
    }
</script>

<%- include('layouts/footer') %>