<%- include('./layouts/header') %> <div class="container my-5">
    <div class="row">
        
        <div class="col-md-3 border-end">
            <div class="d-flex flex-column align-items-center text-center p-3 py-5">
                <img class="rounded-circle mt-5" width="150px" src="/images/<%= user.profileImage || 'default-avatar.png' %>" alt="Profile">
                <span class="font-weight-bold mt-2"><%= user.firstName %> <%= user.lastName %></span>
                <span class="text-black-50"><%= user.email %></span>
            </div>
            
            <div class="list-group list-group-flush">
                <a href="/profile" class="list-group-item list-group-item-action active fw-bold">My Profile</a>
                <a href="/addresses" class="list-group-item list-group-item-action">Address Book</a>
                <a href="/orders" class="list-group-item list-group-item-action">My Orders</a>
                <a href="/wishlist" class="list-group-item list-group-item-action">My Wishlist</a>
                <a href="/logout" class="list-group-item list-group-item-action text-danger">Logout</a>
            </div>
        </div>

        <div class="col-md-9 px-5 py-5">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4 class="fw-bold">My Profile</h4>
                <p class="text-muted">Manage your personal information and account settings</p>
            </div>

            <div class="card p-4 shadow-sm">
                <div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-4">
                    <h5 class="fw-bold mb-0 text-secondary">Personal Information</h5>
                    <button class="btn btn-dark btn-sm px-4">Edit Profile</button>
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="text-muted small d-block">Full Name</label>
                        <span class="fs-5 fw-semibold text-dark"><%= user.firstName %> <%= user.lastName %></span>
                    </div>
                    
                    <div class="col-md-6">
                        <label class="text-muted small d-block">Phone Number</label>
                        <span class="fs-5 fw-semibold text-dark"><%= user.phone || 'Not Added Yet' %></span>
                    </div>

                    <div class="col-md-10 mt-4 pt-3 border-top d-flex justify-content-between align-items-center">
                        <div>
                            <label class="text-muted small d-block">Email Address</label>
                            <span class="fs-5 fw-semibold text-dark"><%= user.email %></span>
                        </div>
                        <button class="btn btn-outline-dark btn-sm px-3">Change Email</button>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<%- include('./layouts/footer') %> 


